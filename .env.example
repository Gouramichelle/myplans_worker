# ── Anthropic ──────────────────────────────────────────────
ANTHROPIC_API_KEY=sk-ant-...

# ── MyPlans API Gateway ────────────────────────────────────
MYPLANS_API_URL=http://localhost:8095

# ── Worker ─────────────────────────────────────────────────
PORT=8099
HOST=0.0.0.0
ENVIRONMENT=development
LOG_LEVEL=DEBUG

# ── Análisis ───────────────────────────────────────────────
# Resolución DPI para conversión de páginas PDF a imagen (150 es buena relación calidad/costo)
PDF_DPI=150
# Máximo de páginas a analizar por request (límite imágenes Claude = 20)
MAX_PAGES=20
# Modelo Claude a usar
CLAUDE_MODEL=claude-sonnet-4-6

# ── CORS ───────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3000,http://localhost:5173
